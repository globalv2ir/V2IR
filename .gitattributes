# Auto-detect text files and normalize line endings
* text=auto

# Kotlin/Java/XML — LF
*.kt text eol=lf
*.java text eol=lf
*.xml text eol=lf
*.json text eol=lf
*.toml text eol=lf
*.md text eol=lf
*.txt text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.properties text eol=lf
*.pro text eol=lf

# Shell scripts — LF
*.sh text eol=lf

# Windows scripts — CRLF
*.bat text eol=crlf
*.ps1 text eol=crlf
*.cmd text eol=crlf

# C/C++ native
*.c text eol=lf
*.cpp text eol=lf
*.h text eol=lf
*.s text eol=lf
*.S text eol=lf

# Binaries — no line ending conversion
*.so binary
*.apk binary
*.aab binary
*.zip binary
*.jar binary
*.keystore binary
*.jks binary
*.dat binary
*.png binary
*.jpg binary
*.jpeg binary
*.webp binary
*.gif binary
*.ico binary
*.ttf binary
*.otf binary
