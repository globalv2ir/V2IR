# ===========================
# Kotlin
# ===========================
.kotlin/

# ===========================
# Room Schema — COMMIT THESE (migration history)
# Generated by Room when exportSchema = true.
# Location: app/schemas/
# ===========================
# Do NOT ignore schemas/ — they should be committed to VCS

# ===========================
# Binaries & Large Assets
# (rebuild with: ./gradlew downloadBinaries)
# ===========================
app/src/main/jniLibs/*/*.so
app/src/main/assets/xray/
app/src/main/assets/geoip.dat
app/src/main/assets/geosite.dat

# ===========================
# hev-socks5-tunnel is provided via JitPack AAR dependency.
# The .so below is only present if someone ran the legacy buildHevTunnel task.
# ===========================
app/src/main/jniLibs/*/libhev-socks5-tunnel.so

# Keep jniLibs folder structure (arm64-v8a, x86_64, armeabi-v7a, x86)
!app/src/main/jniLibs/
!app/src/main/jniLibs/**/.gitkeep

# ===========================
# Kiro IDE artifacts
# ===========================
.artifacts/

# ===========================
# Signing / Secrets
# ===========================
*.keystore
*.jks
keystore.properties
release.properties

# ===========================
# Logs & Temp
# ===========================
*.log
*.tmp
*.zip

